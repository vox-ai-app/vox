{
  "name": "vox",
  "version": "2.1.4",
  "description": "Open-source local-model desktop app for Vox",
  "main": "./out/main/index.js",
  "author": "Arnav Gupta",
  "license": "MIT",
  "homepage": "https://www.vox-ai.chat",
  "repository": {
    "type": "git",
    "url": "https://github.com/vox-ai-app/vox.git"
  },
  "bugs": {
    "url": "https://github.com/vox-ai-app/vox/issues"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "build:packages": "npm run build --workspaces --if-present",
    "release": "changeset publish",
    "postinstall": "electron-builder install-app-deps && node scripts/patch-onnx.js",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "npm run build && electron-builder --mac",
    "build:linux": "npm run build && electron-builder --linux",
    "prepare": "husky",
    "precommit": "lint-staged",
    "spellcheck": "cspell \"src/**/*.{js,jsx,json,md,css}\" \"*.{json,md,mjs,cjs}\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@huggingface/transformers": "^3.4.0",
    "@picovoice/pvrecorder-node": "^1.2.8",
    "@sentry/electron": "^7.10.0",
    "@vox-ai-app/channels": "^1.0.0",
    "@vox-ai-app/indexing": "^1.0.2",
    "@vox-ai-app/integrations": "^1.0.4",
    "@vox-ai-app/mcp": "^1.0.1",
    "@vox-ai-app/scheduler": "^1.0.0",
    "@vox-ai-app/skills": "^1.0.0",
    "@vox-ai-app/storage": "^1.0.2",
    "@vox-ai-app/tools": "^1.0.1",
    "@vox-ai-app/ui": "^1.0.1",
    "@vox-ai-app/voice": "^1.0.1",
    "electron-log": "^5.3.4",
    "electron-updater": "^6.3.9",
    "onnxruntime-web": "^1.24.3",
    "qrcode.react": "^4.2.0",
    "react-icons": "^5.6.0",
    "react-virtuoso": "^4.12.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@commitlint/cli": "^20.3.1",
    "@commitlint/config-conventional": "^20.3.1",
    "@electron-toolkit/eslint-config": "^2.1.0",
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@vitejs/plugin-react": "^5.1.1",
    "cspell": "^9.6.0",
    "electron": "^41.0.3",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "eslint": "^9.7.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.7.4",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "vite": "^7.2.6",
    "vitest": "^4.1.2"
  },
  "lint-staged": {
    "*.js": [
      "eslint",
      "prettier --write",
      "cspell --no-progress"
    ]
  }
}
