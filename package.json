{
  "name": "vox",
  "version": "1.0.0",
  "description": "Open-source local-model desktop app for Vox",
  "main": "./out/main/index.js",
  "author": "Arnav Gupta",
  "license": "MIT",
  "homepage": "https://www.vox-ai.chat",
  "repository": {
    "type": "git",
    "url": "https://github.com/info-arnav/vox.git"
  },
  "bugs": {
    "url": "https://github.com/info-arnav/vox/issues"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "build:packages": "npm run build --workspaces --if-present",
    "release": "changeset publish",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "npm run build && electron-builder --mac",
    "build:linux": "npm run build && electron-builder --linux",
    "prepare": "husky install",
    "precommit": "lint-staged",
    "spellcheck": "cspell \"src/**/*.{js,jsx,json,md,css}\" \"*.{json,md,mjs,cjs}\""
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@info-arnav/vox-ui": "^1.0.0",
    "@info-arnav/vox-tools": "^1.0.0",
    "@info-arnav/vox-integrations": "^1.0.0",
    "@info-arnav/vox-mcp": "^1.0.0",
    "@info-arnav/vox-indexing": "^1.0.0",
    "@info-arnav/vox-voice": "^1.0.0",
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@commitlint/cli": "^20.3.1",
    "@commitlint/config-conventional": "^20.3.1",
    "@electron-toolkit/eslint-config": "^2.1.0",
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@vitejs/plugin-react": "^5.1.1",
    "electron": "^41.0.3",
    "electron-builder": "^26.0.12",
    "cspell": "^9.6.0",
    "electron-vite": "^5.0.0",
    "eslint": "^10.1.0",
    "eslint-plugin-react": "^7.37.5",
    "husky": "^9.1.7",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "prettier": "^3.7.4",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "lint-staged": "^16.2.7",
    "vite": "^7.2.6"
  },
  "lint-staged": {
    "*.js": [
      "eslint",
      "prettier --write",
      "cspell --no-progress"
    ]
  }
}
