{
  "name": "@vox-ai-app/indexing",
  "version": "1.0.1",
  "type": "module",
  "license": "MIT",
  "description": "Local file indexing, full-text search, and document parsing for Vox",
  "main": "./src/index.js",
  "private": false,
  "exports": {
