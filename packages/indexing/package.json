    "url": "https://github.com/vox-ai-app/vox"
  },
  "files": [
    "src",
    "LICENSE",
    "README.md"
  ],
  "peerDependencies": {
    "electron": ">=28.0.0"
  },
  "dependencies": {
    "@vox-ai-app/parser": "^1.0.0",
    "better-sqlite3": "^12.0.0"
