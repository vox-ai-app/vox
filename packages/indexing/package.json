    "./files": "./src/ingest/files.js",
    "./parser": "./src/parser/pool.js",
    "./parser/worker": "./src/parser/worker.js",
    "./process": "./src/process/host.js",
    "./process/entry": "./src/process/process.js",
    "./ipc": "./src/runtime/ipc.js",
    "./logger": "./src/telemetry/logger.js",
    "./sentry": "./src/telemetry/sentry.js"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "repository": {
